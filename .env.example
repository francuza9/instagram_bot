INSTAGRAM_USERNAME=your_bot_username
INSTAGRAM_PASSWORD=your_bot_password
GROQ_API_KEY=your_groq_api_key
CHAT_THREAD_ID=your_chat_thread_id
BOT_DISPLAY_NAME=your_bot_instagram_handle_without_@

# Web cookies for voice messages (optional - only needed for voice note feature)
# To get these: open Instagram in your browser, log into the bot account, press F12,
# go to Application tab (Chrome) or Storage tab (Firefox), click Cookies > https://www.instagram.com,
# and copy the values for each of these cookies:
WEB_CSRFTOKEN=
WEB_DATR=
WEB_DS_USER_ID=
WEB_IG_DID=
WEB_MID=
WEB_RUR=
WEB_SESSIONID=

# Reel reactions (optional - uses free Gemini 2.5 Flash to react to reels)
# Set REACT_TO_REELS in config.py to "FULL", "LITE", or "NONE"
#   FULL = download full video, upload to Gemini (slow but sees everything)
#   LITE = use thumbnail + caption, much faster (recommended for most users)
#   NONE = disabled (default)
# Get a free API key at https://aistudio.google.com/apikey (no credit card needed)
GEMINI_API_KEY=
